# Shared environment source for Lumi and related Trezzhaus repos
# Copy this file to a real .env file or point your runtime to a repo-specific override.
# Fill in only the integrations you plan to use; empty values are fine for local/offline runs.
# Provider/API keys are optional unless the corresponding feature is enabled.
LUMI_RUNTIME_MODE=auto
OPENROUTER_API_KEY=
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
HUGGINGFACE_API_KEY=
STABILITY_API_KEY=
FAL_KEY=
REPLICATE_API_KEY=
DATA_DIR=./.data
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=
CLOUDFLARE_R2_MEMORY_KEY=lumi/memory/lumi-memory.json
ROBLOX_API_KEY=
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=
GITHUB_API_TOKEN=
LUMI_KNOWLEDGE_PATHS=./,../Master-File,../Production-Studio
ACAM_EXCLUDED_ORIGINS=https://studio.trezzhaus.com
ACAM_EXCLUDED_HOSTS=studio.trezzhaus.com
RENDER_WEBHOOK_SECRET=
RENDER_API_KEY=

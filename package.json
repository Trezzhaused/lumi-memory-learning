{
  "name": "webhook-github-action",
  "version": "1.0.0",
  "description": "Render Webhook Receiver Example",
  "main": "app.ts",
  "repository": "https://github.com/render-examples/webhook-github-action",
  "author": "Render Developers",
  "license": "Apache-2.0",
  "private": false,
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node scripts/launcher.cjs",
    "dev": "tsnd --respawn app.ts",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit --pretty",
    "test:guardrails": "npm run build && node --test tests/golden-eval.test.js",
    "test:resources": "npm run build && node --test tests/external-sources.test.js tests/training-resources.test.js",
    "smoke:test": "bash ./scripts/smoke-test.sh",
    "fetch:voxel51": "python3 scripts/fetch_voxel51_dataset_zoo.py && npm run build && node scripts/seed_voxel51_memory.cjs"
  },
  "keywords": [],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@octokit/core": "^6.1.4",
    "@openrouter/sdk": "^0.13.16",
    "express": "^5.0.1",
    "standardwebhooks": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}

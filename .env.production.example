# Production deployment bundle for LUMI
# Copy this file to .env.production and replace the placeholder values before deploying.
# If you prefer a single-file setup, you can keep the same values in .env and use this file only for production-only overrides.

NODE_ENV=production
PORT=3001
LUMI_FAIL_FAST=true
LUMI_BRIDGE_SECRET=replace-with-a-long-random-secret
LUMI_ALLOW_LOCAL_TOOL_EXECUTION=true
LUMI_ALLOW_CLOUD_TOOL_REQUESTS=false
LUMI_LOCAL_FIRST=true
LUMI_CHAT_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
LUMI_ALLOW_EXTERNAL_RESEARCH=true
LUMI_OPENROUTER_REASONING=false
LUMI_OPENROUTER_REASONING_EFFORT=medium

# Chat providers (pick at least one)
OPENROUTER_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434
NVIDIA_API_BASE=
NVIDIA_API_KEY=
NVIDIA_CHAT_MODEL=
NVIDIA_VIDEO_MODEL=
NVIDIA_VIDEO_PATH=/video/generations
NVIDIA_ALLOWED_HOSTS=nvidia.com,localhost,127.0.0.1

# Speech / voice (optional)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Media generation providers (optional)
HUGGINGFACE_API_KEY=
HUGGINGFACE_CLASSIFICATION_MODEL=distilbert-base-uncased-finetuned-sms-spam-detection
STABILITY_API_KEY=
FAL_KEY=
REPLICATE_API_KEY=
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_API_KEY=
COMFYUI_WORKFLOW_T2V=docs/comfyui/wan2.1_t2v.json
COMFYUI_WORKFLOW_I2V=docs/comfyui/wan2.1_native_i2v.json
COMFYUI_TIMEOUT_MS=600000

# Autonomous missions / runtime tuning
DATA_DIR=.data
LUMI_MISSION_STALLED_TIMEOUT_MS=30000
LUMI_MISSION_WORKER_INTERVAL_MS=2000
LUMI_MAX_MISSION_STEPS=5
LUMI_MAX_MISSION_ATTEMPTS=2
LUMI_MISSION_MAX_RUNTIME_MS=180000
LUMI_WORKSPACE_DIR=.workspace
LUMI_ALLOWED_TOOL_COMMANDS=node,npm,pnpm,python,python3
LUMI_REMOTE_OWNER_RUNTIME_URL=
LUMI_REMOTE_OWNER_RUNTIME_TOKEN=
LUMI_INGESTION_ROOT=.data/ingestion
LUMI_ENABLE_GRAPH=true
LUMI_GUARDRAIL_AUDIT_PATH=
LUMI_TENANT_DATA_DIR=.data/tenants
PYTHON_BIN=python3
PYTHON=python3

# External browser automation (optional)
EXTERNAL_BROWSER_PROXY_URL=
EXTERNAL_BROWSER_API_URL=
EXTERNAL_BROWSER_API_KEY=

# Durable storage (optional; local fallback is automatic)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_MEMORY_KEY=lumi/memory/lumi-memory.json
CLOUDFLARE_R2_PUBLIC_URL=

# Roblox publishing (optional)
ROBLOX_API_KEY=
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=

# Security / access control
ACAM_ENABLED=true
ACAM_ALLOWED_ORIGINS=https://app.trezzhaus.com,https://studio.trezzhaus.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ACAM_RATE_LIMIT=120
ACAM_REQUIRE_AUTH=false

# Optional local video workflow integrations
HUNYUAN_VIDEO_REPO_PATH=
HUNYUAN_VIDEO_SCRIPT_PATH=
HUNYUAN_VIDEO_OUTPUT_DIR=.data/video
HUNYUAN_VIDEO_PYTHON_BIN=python3

# Optional Render/GitHub integration hooks
RENDER_WEBHOOK_SECRET=
RENDER_API_URL=https://api.render.com/v1
RENDER_API_KEY=
GITHUB_API_TOKEN=
GITHUB_OWNER_NAME=
GITHUB_REPO_NAME=
GITHUB_WORKFLOW_ID=example.yaml

# External browser automation (used by the Yuanbao / browser-source workflow)
EXTERNAL_BROWSER_PROXY_URL=
EXTERNAL_BROWSER_API_URL=
EXTERNAL_BROWSER_API_KEY=

# Optional local HunyuanVideo checkout integration
# Point this at a local checkout of https://github.com/Tencent-Hunyuan/HunyuanVideo
# or a wrapper script that can generate an MP4 from the prompt.
HUNYUAN_VIDEO_REPO_PATH=
HUNYUAN_VIDEO_SCRIPT_PATH=
HUNYUAN_VIDEO_OUTPUT_DIR=
HUNYUAN_VIDEO_PYTHON_BIN=python3

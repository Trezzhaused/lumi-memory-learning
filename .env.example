# Core runtime
NODE_ENV=development
PORT=3001
LUMI_BRIDGE_SECRET=change-me
LUMI_ALLOW_LOCAL_TOOL_EXECUTION=false
LUMI_ALLOW_CLOUD_TOOL_REQUESTS=false
LUMI_FAIL_FAST=false

# Chat / model providers (optional)
OPENROUTER_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

# Media generation providers (optional)
HUGGINGFACE_API_KEY=
STABILITY_API_KEY=
FAL_KEY=
REPLICATE_API_KEY=

# External browser automation (optional)
EXTERNAL_BROWSER_PROXY_URL=
EXTERNAL_BROWSER_API_URL=
EXTERNAL_BROWSER_API_KEY=

# Durable storage (optional)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# Roblox publishing (optional)
ROBLOX_API_KEY=
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=

# Security / access control (optional)
ACAM_ENABLED=true
ACAM_ALLOWED_ORIGINS=https://app.trezzhaus.com,https://studio.trezzhaus.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ACAM_RATE_LIMIT=60
ACAM_REQUIRE_AUTH=false

# Optional local HunyuanVideo checkout integration
# Point this at a local checkout of https://github.com/Tencent-Hunyuan/HunyuanVideo
# or a wrapper script that can generate an MP4 from the prompt.
HUNYUAN_VIDEO_REPO_PATH=
HUNYUAN_VIDEO_SCRIPT_PATH=
HUNYUAN_VIDEO_OUTPUT_DIR=
HUNYUAN_VIDEO_PYTHON_BIN=python3

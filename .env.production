# Production deployment bundle for LUMI
# Generated locally for this workspace; replace provider credentials and secrets before exposing the service publicly.

NODE_ENV=production
PORT=3001
LUMI_FAIL_FAST=true
LUMI_BRIDGE_SECRET=fac8854bad2d45b92ef34299df122ed7fffd5d914e62ac4b
LUMI_ALLOW_LOCAL_TOOL_EXECUTION=true
LUMI_ALLOW_CLOUD_TOOL_REQUESTS=false

# Chat providers (pick at least one)
OPENROUTER_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

# Media generation providers (optional)
HUGGINGFACE_API_KEY=
STABILITY_API_KEY=
FAL_KEY=
REPLICATE_API_KEY=

# External browser automation (optional)
EXTERNAL_BROWSER_PROXY_URL=
EXTERNAL_BROWSER_API_URL=
EXTERNAL_BROWSER_API_KEY=

# Durable storage (optional; local fallback is automatic)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# Roblox publishing (optional)
ROBLOX_API_KEY=
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=

# Security / access control
ACAM_ENABLED=true
ACAM_ALLOWED_ORIGINS=https://app.trezzhaus.com,https://studio.trezzhaus.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ACAM_RATE_LIMIT=120
ACAM_REQUIRE_AUTH=false

# Optional local video workflow integrations
HUNYUAN_VIDEO_REPO_PATH=
HUNYUAN_VIDEO_SCRIPT_PATH=
HUNYUAN_VIDEO_OUTPUT_DIR=.data/video
HUNYUAN_VIDEO_PYTHON_BIN=python3

# Optional Render/GitHub integration hooks
RENDER_WEBHOOK_SECRET=
RENDER_API_KEY=
GITHUB_API_TOKEN=
GITHUB_OWNER_NAME=
GITHUB_REPO_NAME=
GITHUB_WORKFLOW_ID=example.yaml
